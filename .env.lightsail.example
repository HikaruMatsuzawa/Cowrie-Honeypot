# Lightsail Cowrie settings.
# Copy this file to .env on the Lightsail instance. Do not commit .env.
#
# Before using this file, move the host OpenSSH management port away from TCP 22
# and restrict that management port to the administrator IP address in the
# Lightsail firewall.

COWRIE_IMAGE=cowrie/cowrie:latest
COWRIE_SSH_BIND_ADDRESS=0.0.0.0
COWRIE_SSH_PORT=22
COWRIE_NETWORK_SUBNET=172.30.0.0/24
COWRIE_CONTAINER_IP=172.30.0.10
TZ=UTC
